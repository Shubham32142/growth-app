# ── Postgres / Supabase ──────────────────────────────────────────────────────
# DATABASE_URL — Transaction pooler (port 6543). Used by the running app
# (lib/db/client.ts sets `prepare: false`). User is `postgres.<project-ref>`.
DATABASE_URL=postgres://postgres.<project-ref>:<your-password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# DIRECT_URL — Direct connection (port 5432). Used by drizzle-kit + the
# `db:apply` script for migrations. User is bare `postgres`. Pooler may reject
# some DDL, so always run migrations through this.
# In Supabase: Settings → Database → Connection string → "Direct connection".
DIRECT_URL=postgres://postgres:<your-password>@db.<project-ref>.supabase.co:5432/postgres

# IMPORTANT: if your password contains any of @ : ? / # & %  you must
# URL-encode them. e.g. `p@ssw0rd!` becomes `p%40ssw0rd%21`.
# Supabase Auth / client (public — safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service-role key — bypasses RLS. Used by /api/account (account deletion)
# and the cron route. NEVER prefix with NEXT_PUBLIC_, never expose to the
# browser, server-only.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── AI (BYOK — bring your own key) ───────────────────────────────────────────
# Plan/recap/task generation is BYOK: each user adds their own provider key in
# Settings (OpenAI / Anthropic / Google / OpenRouter). The app stores those keys
# ENCRYPTED using APP_ENCRYPTION_KEY — required for the feature to work.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
APP_ENCRYPTION_KEY=

# ── Search (shared, optional) ────────────────────────────────────────────────
# Tavily powers grounded resource search (the LLM only ranks the results, using
# the requesting user's BYOK key). Optional — resources degrade gracefully.
TAVILY_API_KEY=

# ── Email (Brevo SMTP for Supabase Auth verification emails) ──────────────────
# Login email verification is sent by Supabase Auth over SMTP. On CLOUD: set SMTP
# in Dashboard → Authentication → Emails → SMTP Settings (host smtp-relay.brevo.com,
# port 587, username = your Brevo LOGIN EMAIL, password = this key, sender = your
# verified Brevo sender). For the LOCAL stack: the Brevo block in supabase/config.toml
# reads this var (only needed if you uncomment it; otherwise local mail → Mailpit).
# Get it at Brevo → SMTP & API → SMTP → "Generate a new SMTP key".
BREVO_SMTP_KEY=

# ── Cron auth ────────────────────────────────────────────────────────────────
# Long random string used to authenticate Vercel Cron requests to
# /api/cron/weekly-regen. Vercel will send it as `Authorization: Bearer <value>`.
# Generate: `openssl rand -hex 32` or in PowerShell:
#   [System.Convert]::ToBase64String((1..32 | %{[byte](Get-Random -Max 256)}))
# If unset, the cron endpoint accepts unauthenticated requests (dev only).
CRON_SECRET=
